{
  "name": "hi-voicer",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:offline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-runtime-offline.ps1",
    "check:resources": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-bundled-resources.ps1",
    "prepare:sherpa": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-sherpa-runtime.ps1",
    "prepare:ffmpeg": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-ffmpeg-runtime.ps1",
    "prepare:models": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-offline-models.ps1",
    "prepare:llama": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-llama-runtime.ps1 -Variant cpu",
    "prepare:llama:cuda": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-llama-runtime.ps1 -Variant cuda",
    "prepare:offline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-offline-resources.ps1",
    "package:offline": "npm run prepare:offline && npm run tauri -- build",
    "package:cuda": "npm run prepare:offline && npm run prepare:llama:cuda && npm run tauri -- build",
    "build:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-variants.ps1 -Variant cpu",
    "build:cuda": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-variants.ps1 -Variant cuda",
    "build:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-variants.ps1 -Variant both",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
